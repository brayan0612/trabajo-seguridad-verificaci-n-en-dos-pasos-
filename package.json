// ============================================================
// Droguería Balmoral - Backend API
// Node.js + Express + MariaDB + TOTP (speakeasy) + JWT
// ============================================================

const express   = require('express');
const cors      = require('cors');
const mariadb   = require('mariadb');
const speakeasy = require('speakeasy');
const QRCode    = require('qrcode');
const bcrypt    = require('bcrypt');
const jwt       = require('jsonwebtoken');

const app  = express();
const PORT = process.env.PORT || 3000;
const JWT_SECRET = process.env.JWT_SECRET || 'balmoral_jwt_secreto_super_seguro_2024';

// ------------------------------------------------------------
// Middlewares globales
// ------------------------------------------------------------
app.use(cors());
app.use(express.json());
app.use(express.static('/app/frontend'));

// ------------------------------------------------------------
// Pool de conexiones a MariaDB
// ------------------------------------------------------------
const pool = mariadb.createPool({
  host:            process.env.DB_HOST     || 'db',
  port:            Number(process.env.DB_PORT) || 3306,
  user:            process.env.DB_USER     || 'balmoral_user',
  password:        process.env.DB_PASSWORD || 'balmoral_pass',
  database:        process.env.DB_NAME     || 'balmoral_db',
  connectionLimit: 10,
  acquireTimeout:  10000,
});

async function query(sql, params) {
  let conn;
  try {
    conn = await pool.getConnection();
    return await conn.query(sql, params);
  } finally {
    if (conn) conn.release();
  }
}

// ============================================================
// MIDDLEWARE: VERIFICAR JWT (sesión activa)
// Protege todas las rutas del dashboard.
// El frontend envía el token en: Authorization: Bearer <jwt>
// ============================================================
function verificarJWT(req, res, next) {
  const auth = req.headers['authorization'];
  if (!auth || !auth.startsWith('Bearer ')) {
    return res.status(401).json({ error: 'Sesión requerida. Inicia sesión.' });
  }
  const token = auth.split(' ')[1];
  try {
    req.usuario = jwt.verify(token, JWT_SECRET);
    next();
  } catch {
    return res.status(401).json({ error: 'Sesión expirada o inválida. Inicia sesión de nuevo.' });
  }
}

// ============================================================
// MIDDLEWARE: VERIFICAR MFA EN OPERACIONES DE ESCRITURA
// Solo aplica a rutas ya protegidas por JWT.
// Exige header: x-mfa-token con un TOTP válido.
// ============================================================
async function verificarMFA(req, res, next) {
  const token = req.headers['x-mfa-token'];

  if (!token) {
    return res.status(401).json({
      error: 'Se requiere el header x-mfa-token para esta operación.',
    });
  }

  try {
    const rows = await query(
      'SELECT `2fa_secret`, `2fa_enabled` FROM administradores WHERE usuario = ?',
      [req.usuario.usuario]
    );

    if (!rows.length || !rows[0]['2fa_enabled'] || !rows[0]['2fa_secret']) {
      return res.status(401).json({
        error: 'El 2FA no está activado. Complete el enrolamiento primero.',
      });
    }

    const esValido = speakeasy.totp.verify({
      secret:   rows[0]['2fa_secret'],
      encoding: 'base32',
      token:    String(token),
      window:   1,
    });

    if (!esValido) {
      return res.status(401).json({ error: 'Código 2FA incorrecto o expirado.' });
    }

    next();
  } catch (err) {
    console.error('[MFA]', err.message);
    res.status(500).json({ error: 'Error interno al verificar MFA.' });
  }
}

// ============================================================
// LOGIN DE DOS PASOS
// ============================================================

/**
 * POST /api/auth/login
 * Paso 1: valida usuario + contraseña.
 * Si el 2FA está activado → devuelve { requiere2fa: true }
 * Si el 2FA NO está activado → emite JWT directamente.
 * Body: { usuario, contrasena }
 */
app.post('/api/auth/login', async (req, res) => {
  const { usuario, contrasena } = req.body;

  if (!usuario || !contrasena) {
    return res.status(400).json({ error: 'Usuario y contraseña son obligatorios.' });
  }

  try {
    const rows = await query(
      'SELECT id, usuario, contrasena, `2fa_enabled`, `2fa_secret` FROM administradores WHERE usuario = ?',
      [usuario]
    );

    if (!rows.length) {
      return res.status(401).json({ error: 'Credenciales incorrectas.' });
    }

    const admin = rows[0];

    // Comparar contraseña con hash bcrypt
    const credencialesOk = await bcrypt.compare(contrasena, admin.contrasena);
    if (!credencialesOk) {
      return res.status(401).json({ error: 'Credenciales incorrectas.' });
    }

    // Si el 2FA está activo, informar al frontend para que pida el TOTP
    if (admin['2fa_enabled']) {
      return res.json({
        requiere2fa: true,
        mensaje: 'Contraseña correcta. Introduce el código de tu autenticador.',
      });
    }

    // Sin 2FA: emitir JWT directamente
    const token = jwt.sign(
      { id: Number(admin.id), usuario: admin.usuario },
      JWT_SECRET,
      { expiresIn: '8h' }
    );

    res.json({ token, usuario: admin.usuario });

  } catch (err) {
    console.error('[Login]', err.message);
    res.status(500).json({ error: 'Error interno en el login.' });
  }
});

/**
 * POST /api/auth/login/totp
 * Paso 2: valida el código TOTP tras un login correcto.
 * Si el token es válido → emite JWT de sesión.
 * Body: { usuario, token }
 */
app.post('/api/auth/login/totp', async (req, res) => {
  const { usuario, token } = req.body;

  if (!usuario || !token) {
    return res.status(400).json({ error: 'Usuario y token son obligatorios.' });
  }

  try {
    const rows = await query(
      'SELECT id, usuario, `2fa_secret`, `2fa_enabled` FROM administradores WHERE usuario = ?',
      [usuario]
    );

    if (!rows.length || !rows[0]['2fa_enabled'] || !rows[0]['2fa_secret']) {
      return res.status(401).json({ error: 'No se puede verificar el 2FA para este usuario.' });
    }

    const esValido = speakeasy.totp.verify({
      secret:   rows[0]['2fa_secret'],
      encoding: 'base32',
      token:    String(token),
      window:   1,
    });

    if (!esValido) {
      return res.status(401).json({ error: 'Código 2FA incorrecto o expirado.' });
    }

    // Emitir JWT de sesión
    const jwtToken = jwt.sign(
      { id: Number(rows[0].id), usuario: rows[0].usuario },
      JWT_SECRET,
      { expiresIn: '8h' }
    );

    res.json({ token: jwtToken, usuario: rows[0].usuario });

  } catch (err) {
    console.error('[Login TOTP]', err.message);
    res.status(500).json({ error: 'Error interno al verificar TOTP.' });
  }
});

// ============================================================
// ENDPOINTS DE 2FA (enrolamiento — requieren JWT)
// ============================================================

/**
 * GET /api/2fa/setup
 * Genera un secreto TOTP nuevo y retorna la URL + QR base64.
 * Requiere sesión activa (JWT).
 */
app.get('/api/2fa/setup', verificarJWT, async (req, res) => {
  try {
    const secreto = speakeasy.generateSecret({
      name:   `Balmoral - ${req.usuario.usuario}`,
      issuer: 'Droguería Balmoral',
      length: 20,
    });

    await query(
      'UPDATE administradores SET `2fa_secret` = ?, `2fa_enabled` = 0 WHERE usuario = ?',
      [secreto.base32, req.usuario.usuario]
    );

    const qrDataUrl = await QRCode.toDataURL(secreto.otpauth_url);

    res.json({
      secreto:  secreto.base32,
      otpauth:  secreto.otpauth_url,
      qr:       qrDataUrl,
      mensaje:  'Escanea el QR con Google Authenticator o Authy.',
    });
  } catch (err) {
    console.error('[2FA Setup]', err.message);
    res.status(500).json({ error: 'No se pudo generar el secreto 2FA.' });
  }
});

/**
 * POST /api/2fa/verify
 * Activa el 2FA tras verificar el primer token del dispositivo.
 * Requiere sesión activa (JWT).
 * Body: { token }
 */
app.post('/api/2fa/verify', verificarJWT, async (req, res) => {
  const { token } = req.body;
  if (!token) return res.status(400).json({ error: 'Se requiere el campo token.' });

  try {
    const rows = await query(
      'SELECT `2fa_secret` FROM administradores WHERE usuario = ?',
      [req.usuario.usuario]
    );

    if (!rows.length || !rows[0]['2fa_secret']) {
      return res.status(400).json({ error: 'Primero genera el secreto con GET /api/2fa/setup.' });
    }

    const esValido = speakeasy.totp.verify({
      secret:   rows[0]['2fa_secret'],
      encoding: 'base32',
      token:    String(token),
      window:   1,
    });

    if (!esValido) {
      return res.status(401).json({ error: 'Token incorrecto o expirado.' });
    }

    await query(
      'UPDATE administradores SET `2fa_enabled` = 1 WHERE usuario = ?',
      [req.usuario.usuario]
    );

    res.json({ exito: true, mensaje: '✅ 2FA activado correctamente.' });
  } catch (err) {
    console.error('[2FA Verify]', err.message);
    res.status(500).json({ error: 'Error interno al verificar el token.' });
  }
});

/**
 * GET /api/2fa/estado
 * Devuelve si el 2FA está activado. Requiere JWT.
 */
app.get('/api/2fa/estado', verificarJWT, async (req, res) => {
  try {
    const rows = await query(
      'SELECT `2fa_enabled` FROM administradores WHERE usuario = ?',
      [req.usuario.usuario]
    );
    res.json({ activado: rows.length ? Boolean(rows[0]['2fa_enabled']) : false });
  } catch (err) {
    res.status(500).json({ error: 'Error al consultar estado 2FA.' });
  }
});

// ============================================================
// ENDPOINTS DE MEDICAMENTOS (CRUD)
// Todos requieren JWT. Las escrituras también requieren MFA.
// ============================================================

app.get('/api/medicamentos', verificarJWT, async (req, res) => {
  try {
    const rows = await query('SELECT * FROM medicamentos ORDER BY nombre ASC');
    res.json(rows);
  } catch (err) {
    res.status(500).json({ error: 'Error al obtener medicamentos.' });
  }
});

app.get('/api/medicamentos/:id', verificarJWT, async (req, res) => {
  try {
    const rows = await query('SELECT * FROM medicamentos WHERE id = ?', [req.params.id]);
    if (!rows.length) return res.status(404).json({ error: 'Medicamento no encontrado.' });
    res.json(rows[0]);
  } catch (err) {
    res.status(500).json({ error: 'Error al obtener medicamento.' });
  }
});

app.post('/api/medicamentos', verificarJWT, verificarMFA, async (req, res) => {
  const { nombre, descripcion, precio, stock, categoria } = req.body;
  if (!nombre || precio === undefined || stock === undefined) {
    return res.status(400).json({ error: 'Faltan campos: nombre, precio, stock.' });
  }
  try {
    const result = await query(
      'INSERT INTO medicamentos (nombre, descripcion, precio, stock, categoria) VALUES (?, ?, ?, ?, ?)',
      [nombre, descripcion || '', precio, stock, categoria || '']
    );
    res.status(201).json({ id: Number(result.insertId), mensaje: 'Medicamento creado.' });
  } catch (err) {
    res.status(500).json({ error: 'Error al crear medicamento.' });
  }
});

app.put('/api/medicamentos/:id', verificarJWT, verificarMFA, async (req, res) => {
  const { nombre, descripcion, precio, stock, categoria } = req.body;
  try {
    const result = await query(
      'UPDATE medicamentos SET nombre=?, descripcion=?, precio=?, stock=?, categoria=? WHERE id=?',
      [nombre, descripcion, precio, stock, categoria, req.params.id]
    );
    if (result.affectedRows === 0) return res.status(404).json({ error: 'No encontrado.' });
    res.json({ mensaje: 'Medicamento actualizado.' });
  } catch (err) {
    res.status(500).json({ error: 'Error al actualizar medicamento.' });
  }
});

app.delete('/api/medicamentos/:id', verificarJWT, verificarMFA, async (req, res) => {
  try {
    const result = await query('DELETE FROM medicamentos WHERE id=?', [req.params.id]);
    if (result.affectedRows === 0) return res.status(404).json({ error: 'No encontrado.' });
    res.json({ mensaje: 'Medicamento eliminado.' });
  } catch (err) {
    res.status(500).json({ error: 'Error al eliminar medicamento.' });
  }
});

// ============================================================
// Healthcheck
// ============================================================
app.get('/api/health', (req, res) => res.json({ estado: 'OK', timestamp: new Date() }));

// ============================================================
// Iniciar servidor
// ============================================================
app.listen(PORT, () => {
  console.log(`✅ API Balmoral escuchando en http://localhost:${PORT}`);
});
